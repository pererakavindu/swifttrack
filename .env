# SwiftLogistics - SwiftTrack Platform Environment Variables

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=swifttrack
RABBITMQ_PASS=swifttrack123
RABBITMQ_VHOST=/

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=swifttrack-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Services (internal Docker network)
GATEWAY_HOST=gateway
GATEWAY_PORT=8000
ORCHESTRATOR_HOST=orchestrator
ORCHESTRATOR_PORT=8001
CMS_ADAPTER_HOST=cms-adapter
CMS_ADAPTER_PORT=8002
ROS_HOST=mock-ros
ROS_PORT=8003
WMS_ADAPTER_HOST=wms-adapter
WMS_ADAPTER_PORT=8004
MOCK_CMS_HOST=mock-cms
MOCK_CMS_PORT=8005
MOCK_WMS_HOST=mock-wms
MOCK_WMS_PORT=9000
